{
  "name": "bizflow",
  "version": "0.1.0",
  "private": true,
  "description": "BizFlow SA multi-tenant SaaS platform for South African SMEs.",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "turbo run dev",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @bizflow/database",
    "db:migrate": "npm run db:migrate -w @bizflow/database",
    "db:seed": "npm run db:seed -w @bizflow/database"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
